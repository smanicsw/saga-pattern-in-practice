# Runtime
NODE_ENV=production

# Service ports
ORDER_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3002
INVENTORY_SERVICE_PORT=3003

# Database credentials
ORDER_DB_USER=postgres
ORDER_DB_PASSWORD=change_me_order
ORDER_DB_NAME=order_db

PAYMENTS_DB_USER=postgres
PAYMENTS_DB_PASSWORD=change_me_payments
PAYMENTS_DB_NAME=payments_db

INVENTORY_DB_USER=postgres
INVENTORY_DB_PASSWORD=change_me_inventory
INVENTORY_DB_NAME=inventory_db

# Database URLs used by services (inside Docker network)
ORDER_DATABASE_URL=postgresql://postgres:change_me_order@order-db:5432/order_db
PAYMENT_DATABASE_URL=postgresql://postgres:change_me_payments@payments-db:5432/payments_db
INVENTORY_DATABASE_URL=postgresql://postgres:change_me_inventory@inventory-db:5432/inventory_db

# Optional host-exposed DB ports
ORDER_DB_HOST_PORT=5433
PAYMENTS_DB_HOST_PORT=5434
INVENTORY_DB_HOST_PORT=5435
