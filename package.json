{
  "name": "saga-pattern-in-practice",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "corepack pnpm --filter @saga/order-service dev",
    "dev:order": "corepack pnpm --filter @saga/order-service dev",
    "dev:payments": "corepack pnpm --filter @saga/payments-service dev",
    "dev:inventory": "corepack pnpm --filter @saga/inventory-service dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
